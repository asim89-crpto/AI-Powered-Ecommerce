@page "/"

<PageTitle>AI Powered Ecommerce</PageTitle>

<div class="container-fluid p-0">

    <!-- Hero Banner -->

    <div class="bg-dark text-white text-center p-5 rounded shadow">

        <h1 class="display-3 fw-bold">
            AI Powered Ecommerce
        </h1>

        <p class="lead mt-3">

            Shop Smarter with AI Recommendations

        </p>

        <a href="/products"
           class="btn btn-warning btn-lg mt-3">

            🛒 Shop Now

        </a>

    </div>

    <br />

    <!-- Features -->

    <div class="row text-center">

        <div class="col-md-4">

            <div class="card shadow">

                <div class="card-body">

                    <h2>🚚</h2>

                    <h4>Fast Delivery</h4>

                    <p>

                        Get your products delivered
                        quickly and safely.

                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow">

                <div class="card-body">

                    <h2>🤖</h2>

                    <h4>AI Recommendations</h4>

                    <p>

                        Smart product recommendations
                        based on customer behaviour.

                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow">

                <div class="card-body">

                    <h2>🔒</h2>

                    <h4>Secure Shopping</h4>

                    <p>

                        Safe payments and secure
                        authentication.

                    </p>

                </div>

            </div>

        </div>

    </div>

    <br />

    <!-- Categories -->

    <h2 class="text-center">

        Shop By Category

    </h2>

    <br />

    <div class="row text-center">

        <div class="col-md-4">

            <div class="card border-primary shadow">

                <div class="card-body">

                    <h1>🏏</h1>

                    <h4>Cricket</h4>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-success shadow">

                <div class="card-body">

                    <h1>💻</h1>

                    <h4>Electronics</h4>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-danger shadow">

                <div class="card-body">

                    <h1>📚</h1>

                    <h4>Books</h4>

                </div>

            </div>

        </div>

    </div>

    <br />

    <!-- CTA -->

    <div class="bg-light p-5 rounded text-center shadow">

        <h2>

            Ready to explore our products?

        </h2>

        <br />

        <a href="/products"
           class="btn btn-primary btn-lg">

            Browse Products

        </a>

    </div>

</div>